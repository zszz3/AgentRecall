{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals", "vite/client"]
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/automation/engine/shared/bundled-skills/**/*.ts"]
}
